SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
PYTHON_BIN=/srv/apps/agronomy-llm-benchmarking/venv/bin/python

# Poll OpenRouter every 6 hours.
# The repo's benchmark logic will only run newly discovered / incomplete models,
# then commit and push tracked leaderboard updates when they change.
15 */6 * * * /srv/apps/agronomy-llm-benchmarking/run_benchmark_cron.sh
