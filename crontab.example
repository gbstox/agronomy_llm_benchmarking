# Install manually on the target machine, for example:
#   crontab /absolute/path/to/this/file
#
# Update the repo path below before installing.

SHELL=/bin/bash
PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin

# Poll OpenRouter every 6 hours.
# The repo's benchmark logic will only run newly discovered / incomplete models.
15 */6 * * * /absolute/path/to/agronomy_llm_benchmarking/run_benchmark_cron.sh
