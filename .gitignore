# .gitignore

# Ignore Python build artifacts
__pycache__/
*.py[cod]
*$py.class

# Ignore all log files
*.log

# Ignore the virtual environment folder
venv/
.venv/

# Ignore the database file
*.db

# Ignore the .DS_Store file (Mac OS)
.DS_Store

# Ignore the .env file
.env

# Ignore the .idea folder (PyCharm)
.idea/

# Ignore Jupyter Notebook files
*.ipynb_checkpoints/

# Ignore VS Code settings
.vscode/

# Other files
/private_api_calls.py
/benchmark_results_tests
/benchmark_questions
# Raw per-model result files embed the full question text and answer key, so
# they are kept local-only to prevent the benchmark from being solvable. Only
# the README leaderboard and charts are published.
/benchmark_results/model_results/
/benchmark_results/cron_logs
/benchmark_results/openrouter_discovery_state.json
/benchmark_results/run_heartbeat.json.*.tmp
/result_analysis.py
/scratchpad.txt
