# .gitignore

# Ignore Python build artifacts
__pycache__/
*.py[cod]
*$py.class

# Ignore all log files
*.log

# Ignore the virtual environment folder
venv/
.venv/

# Ignore the database file
*.db

# Ignore the .DS_Store file (Mac OS)
.DS_Store

# Ignore the .env file
.env

# Ignore the .idea folder (PyCharm)
.idea/

# Ignore Jupyter Notebook files
*.ipynb_checkpoints/

# Ignore VS Code settings
.vscode/
<FINAL_CODE>

# Other files
/private_api_calls.py
/benchmark_results_tests
/benchmark_questions
/benchmark_results/model_results/*
!/benchmark_results/model_results/moonshotai_kimi-k2.5_answers.json
!/benchmark_results/model_results/z-ai_glm-5_answers.json
/benchmark_results/cron_logs
/benchmark_results/openrouter_discovery_state.json
/result_analysis.py
/scratchpad.txt
